{
  "name": "skills",
  "private": true,
  "description": "Marketplace catalog for Patina Project plugins and packaged skills (Codex + Claude)",
  "author": {
    "name": "Ted Mader",
    "email": "ted@patinaproject.com",
    "url": "https://github.com/tlmader"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "postinstall": "bash scripts/install-third-party-skills.sh",
    "commit": "git-cz",
    "commit:retry": "git-cz --retry",
    "commitlint": "commitlint",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#docs/superpowers/**\" \"#skills/**\" \"#.agents/skills/**\" \"#.claude/skills/**\"",
    "skills:install": "bash scripts/install-third-party-skills.sh",
    "verify:dogfood": "bash scripts/verify-dogfood.sh",
    "verify:marketplace": "bash scripts/verify-marketplace.sh",
    "verify:superteam": "bash scripts/verify-superteam-contract.sh",
    "apply:scaffold-repository": "node scripts/apply-scaffold-repository.js skills/scaffold-repository",
    "apply:scaffold-repository:check": "node scripts/apply-scaffold-repository.js skills/scaffold-repository --check"
  },
  "config": {
    "commitizen": {
      "path": "cz-customizable"
    },
    "cz-customizable": {
      "config": "commitizen.config.js"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "markdownlint-cli2": "^0.14.0"
  }
}
